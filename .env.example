# Base URL of the Proxmox VE API, including scheme and port.
PROXMOX_HOST=https://pve.local:8006

# API token id in the form USER@REALM!TOKENID (no secret here).
PROXMOX_TOKEN_ID=root@pam!mcp

# API token secret (the UUID shown once when the token is created).
PROXMOX_TOKEN_SECRET=00000000-0000-0000-0000-000000000000

# Accept self-signed certificates. Leave false in production.
PROXMOX_INSECURE_TLS=false

# Read-only mode. When true, write/destructive tools are not registered at all.
# Start with true and flip to false once you trust the setup.
PVE_READONLY=true

# Optional comma-separated allowlist restricting which nodes may be targeted.
# PVE_NODE_ALLOWLIST=pve1,pve2

# Optional comma-separated allowlist restricting which guest IDs may be targeted.
# PVE_VMID_ALLOWLIST=100,101,102

# HTTP request timeout in milliseconds (single request, not task polling).
# PROXMOX_REQUEST_TIMEOUT_MS=30000

# Maximum time to wait for an async task (UPID) to finish, in milliseconds.
# PVE_TASK_TIMEOUT_MS=600000

# Log level: debug | info | warn | error
# LOG_LEVEL=info
